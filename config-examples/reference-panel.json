{
  "v": 1,
  "theme": "nordic-oak",
  "pages": [
    {
      "id": "salone",
      "title": "Salone",
      "type": "grid",
      "grid": { "columns": 4, "rows": 4 },
      "tiles": [
        {
          "id": "scene_tv",
          "type": "button",
          "col": 1, "row": 1, "colSpan": 2, "rowSpan": 2,
          "shape": "square",
          "icon": "media", "label": "Tv sera",
          "behavior": "push",
          "entity": "scene.tv",
          "events": ["press"],
          "bindings": { "press": { "action": "scene", "entity_id": "scene.tv" } }
        },
        {
          "id": "salone_main",
          "type": "button",
          "col": 3, "row": 1,
          "icon": "light", "label": "Salone",
          "behavior": "toggle",
          "activeMode": "lit",
          "entity": "light.luci_del_salone",
          "events": ["press", "long"],
          "bindings": {
            "press": { "action": "toggle" },
            "long": { "action": "scene", "entity_id": "scene.luci_salone_soft" }
          }
        },
        {
          "id": "tavolo",
          "type": "button",
          "col": 3, "row": 2,
          "icon": "light", "label": "Tavolo",
          "behavior": "toggle",
          "activeMode": "lit",
          "entity": "light.tavolo_salone_zb",
          "events": ["press"],
          "bindings": { "press": { "action": "toggle" } }
        },
        {
          "id": "dim_salone",
          "type": "dimmer",
          "col": 4, "row": 1, "rowSpan": 3,
          "orientation": "vertical",
          "segments": 12,
          "step": 1,
          "holdRepeatMs": 350,
          "entity": "light.luci_del_salone",
          "bindings": { "dim": { "action": "brightness" } }
        },
        {
          "id": "prese",
          "type": "button",
          "col": 1, "row": 3,
          "shape": "circle",
          "icon": "outlet", "label": "Prese",
          "statusDot": { "entity": "switch.prese_8_1_manu_prese" },
          "behavior": "toggle",
          "activeMode": "lit",
          "entity": "switch.prese_8_1_manu_prese",
          "events": ["press"],
          "bindings": { "press": { "action": "toggle" } }
        },
        {
          "id": "mensola",
          "type": "button",
          "col": 2, "row": 3,
          "icon": "light", "label": "Mensola",
          "statusDot": true,
          "behavior": "toggle",
          "activeMode": "lit",
          "entity": "light.mensola",
          "events": ["press"],
          "bindings": { "press": { "action": "toggle" } }
        },
        {
          "id": "cucina",
          "type": "button",
          "col": 3, "row": 3,
          "icon": "light", "label": "Cucina",
          "behavior": "toggle",
          "activeMode": "inset",
          "entity": "light.cucina_soffitto",
          "events": ["press", "double"],
          "bindings": {
            "press": { "action": "toggle" },
            "double": { "action": "turn_off" }
          }
        },
        {
          "id": "dim_cucina",
          "type": "dimmer",
          "col": 1, "row": 4, "colSpan": 2,
          "orientation": "horizontal",
          "segments": 6,
          "step": 1,
          "holdRepeatMs": 350,
          "entity": "light.cucina_soffitto",
          "bindings": { "dim": { "action": "brightness" } }
        },
        {
          "id": "off_all",
          "type": "button",
          "col": 3, "row": 4,
          "icon": "power", "label": "Spegni",
          "behavior": "push",
          "entity": "scene.spegni_tutto",
          "events": ["press"],
          "bindings": { "press": { "action": "scene", "entity_id": "scene.spegni_tutto" } }
        },
        {
          "id": "goto_scenes",
          "type": "button",
          "col": 4, "row": 4,
          "icon": "scene", "label": "Scene",
          "behavior": "push",
          "events": ["press"],
          "bindings": { "press": { "action": "none" } }
        }
      ]
    },
    {
      "id": "scene",
      "title": "Scene",
      "type": "grid",
      "grid": { "columns": 4, "rows": 3 },
      "tiles": [
        {
          "id": "salone_on",
          "type": "button",
          "col": 1, "row": 1,
          "icon": "power", "label": "Salone On",
          "behavior": "push",
          "entity": "scene.salone_on",
          "events": ["press"],
          "bindings": { "press": { "action": "scene", "entity_id": "scene.salone_on" } }
        },
        {
          "id": "salone_50",
          "type": "button",
          "col": 2, "row": 1,
          "icon": "brightness", "label": "Salone 50%",
          "behavior": "push",
          "entity": "scene.salone_50",
          "events": ["press"],
          "bindings": { "press": { "action": "scene", "entity_id": "scene.salone_50" } }
        },
        {
          "id": "soft",
          "type": "button",
          "col": 3, "row": 1,
          "icon": "night", "label": "Soft",
          "behavior": "push",
          "entity": "scene.luci_salone_soft",
          "events": ["press"],
          "bindings": { "press": { "action": "scene", "entity_id": "scene.luci_salone_soft" } }
        },
        {
          "id": "off_all_2",
          "type": "button",
          "col": 4, "row": 1,
          "icon": "power", "label": "Tutto Off",
          "behavior": "push",
          "entity": "scene.spegni_tutto",
          "events": ["press"],
          "bindings": { "press": { "action": "scene", "entity_id": "scene.spegni_tutto" } }
        },
        {
          "id": "scene_switcher",
          "type": "switcher",
          "col": 1, "row": 3, "colSpan": 4,
          "stateKey": "scene_switch",
          "items": [
            { "value": "day",   "icon": "sun",  "label": "Day" },
            { "value": "relax", "icon": "leaf", "label": "Relax" },
            { "value": "movie", "icon": "tv",   "label": "Movie" },
            { "value": "night", "icon": "moon", "label": "Night" }
          ],
          "events": ["state"],
          "bindings": {
            "state:day":   { "action": "scene", "entity_id": "scene.salone_on" },
            "state:relax": { "action": "scene", "entity_id": "scene.luci_salone_soft" },
            "state:movie": { "action": "scene", "entity_id": "scene.tv" },
            "state:night": { "action": "scene", "entity_id": "scene.spegni_tutto" }
          }
        },
        {
          "id": "scene_mode",
          "type": "button",
          "col": 1, "row": 2, "colSpan": 2,
          "shape": "square",
          "behavior": "state",
          "stateKey": "scene_mode",
          "states": [
            { "value": "off",   "icon": "power",      "label": "Off",    "active": false },
            { "value": "day",   "icon": "brightness", "label": "Giorno" },
            { "value": "night", "icon": "night",      "label": "Notte" }
          ],
          "events": ["state"],
          "bindings": {
            "state:off":   { "action": "scene", "entity_id": "scene.spegni_tutto" },
            "state:day":   { "action": "scene", "entity_id": "scene.salone_on" },
            "state:night": { "action": "scene", "entity_id": "scene.luci_salone_soft" }
          }
        },
        {
          "id": "split_luci",
          "type": "split",
          "col": 3, "row": 2, "colSpan": 2,
          "orientation": "horizontal",
          "buttons": [
            {
              "id": "luci",
              "icon": "bulb", "label": "Luci",
              "state": {
                "entity": "light.luci_del_salone",
                "on": { "operator": "equals", "compareTo": "on" }
              },
              "bindings": {
                "press:off": { "action": "turn_on" },
                "press:on": [
                  { "action": "turn_off" },
                  { "action": "call", "service": "light.turn_off" }
                ]
              }
            },
            {
              "id": "tavolo",
              "icon": "lamp", "label": "Tavolo",
              "state": {
                "entity": "light.tavolo_salone_zb",
                "on":    { "operator": "equals", "compareTo": "on" },
                "inset": { "entity": "light.cucina_soffitto", "operator": "equals", "compareTo": "on" }
              },
              "bindings": {
                "press:off":   { "action": "none" },
                "press:on":    { "action": "none" },
                "press:inset": { "action": "none" }
              }
            }
          ]
        }
      ]
    },
    {
      "id": "clock",
      "title": "Clock",
      "type": "clock"
    }
  ]
}
